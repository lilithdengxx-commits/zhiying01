# 智鹰后端 - 大模型评分配置
# 复制本文件为 .env，填入你的配置，重启后端即可开启 AI 评分
# 未填写 LLM_API_KEY 时自动降级为关键词规则评分，不影响正常运行

# ============================================================
# 推荐方案一：DeepSeek（国内可用，成本极低 ≈ ¥0.001/条）
# ============================================================
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ============================================================
# 方案二：OpenAI（需翻墙，约 $0.0001/条）
# ============================================================
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ============================================================
# 方案三：阿里云百炼/通义千问（国内，中等成本）
# ============================================================
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo

# ============================================================
# 方案四：本地 Ollama（完全免费，需本地安装 Ollama + 下载模型）
# 安装：https://ollama.com  然后运行 ollama pull qwen2.5:7b
# ============================================================
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
